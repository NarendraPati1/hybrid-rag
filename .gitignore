# ── Secrets (NEVER commit these) ──────────────────────────────────────────────
.env
*.env

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[oc]
*.pyo
.Python
*.egg-info/
.eggs/
dist/
build/
wheels/
*.whl

# ── Virtual environments ───────────────────────────────────────────────────────
.venv/
venv/
env/
rag/            # old venv accidentally named 'rag'

